# Server
PORT=5000
NODE_ENV=development

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# MongoDB Atlas
# 1. Create a free cluster at https://www.mongodb.com/cloud/atlas
# 2. Database Access -> add a user with a password
# 3. Network Access -> allow your IP (or 0.0.0.0/0 for dev)
# 4. Connect -> Drivers -> copy the connection string and swap in your db name
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/luxestyle?retryWrites=true&w=majority

# Clerk (https://dashboard.clerk.com)
# Secret key: Dashboard -> API Keys -> Secret key
CLERK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_KEY
# Webhook secret: Dashboard -> Webhooks -> Add endpoint (https://<your-server>/api/webhooks/clerk)
#   subscribe to user.created, user.updated, user.deleted -> copy the "Signing Secret"
CLERK_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_KEY

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
